# Repo-root .env.example for UAT + future dev env knobs.
#
# Copy to `.env` (repo root) and populate from vault. The file is
# gitignored repo-wide (`.env*` in /.gitignore). Never commit a populated
# copy.
#
# Refresh workflow — see telegram-plugin/uat/SETUP.md §6. tl;dr from the
# test-harness agent (which has these keys in its ACL):
#
#   read -sp "Vault passphrase: " SWITCHROOM_VAULT_PASSPHRASE; echo
#   export SWITCHROOM_VAULT_PASSPHRASE
#   ( umask 077 && {
#     echo "TELEGRAM_API_ID=$(docker exec switchroom-test-harness switchroom vault get telegram-uat-api-id)"
#     echo "TELEGRAM_API_HASH=$(docker exec switchroom-test-harness switchroom vault get telegram-uat-api-hash)"
#     echo "TELEGRAM_UAT_DRIVER_SESSION=$(docker exec switchroom-test-harness switchroom vault get telegram-uat-driver-session)"
#     echo "TELEGRAM_TEST_BOT_USERNAME=meken_switchroom_test_bot"
#   } > .env )
#   unset SWITCHROOM_VAULT_PASSPHRASE
#
# (umask 077 ensures the file is never world-readable between creation and
# the implicit chmod from > redirection.)

# --- Telegram UAT driver (mtcute) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_UAT_DRIVER_SESSION=
TELEGRAM_TEST_BOT_USERNAME=meken_switchroom_test_bot

# --- Bot tokens (install-validation / blank-server e2e) ---
# BotFather tokens for the admin + agent bots a fresh `switchroom setup`
# provisions. Secrets — pull from vault, never paste a real token here.
# The *_USERNAME keys are non-secret host config (the @handle without @).
SWITCHROOM_ADMIN_BOT_TOKEN=
SWITCHROOM_ADMIN_BOT_USERNAME=
SWITCHROOM_AGENT_BOT_TOKEN=
SWITCHROOM_AGENT_BOT_USERNAME=

# --- One-shot Claude OAuth setup token ---
# Single-use `code#verifier` consumed by `switchroom setup --via-claude`
# to seed the first account. Secret; expires fast. From vault.
CLAUDE_OAUTH_SETUP_TOKEN=

# --- GitHub PAT (install-validation VM only) ---
# Used by the blank-server install-reval harness to clone/push. Secret.
# Scope it minimally; never the operator's personal long-lived PAT.
GITHUB_PAT=
