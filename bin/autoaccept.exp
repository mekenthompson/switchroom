#!/usr/bin/expect -f
#
# Switchroom autoaccept: automatically respond to Claude Code FIRST-RUN
# TUI prompts that appear when launching a fresh agent (theme picker,
# provider picker, MCP trust dialog, dev-channels acknowledgement).
#
# IMPORTANT: this script deliberately does NOT auto-accept per-tool
# permission prompts (the "Yes and don't ask again" dialog). Those
# prompts are the security boundary that lets Ken approve or deny
# individual tool calls from Telegram via the inline-button flow in
# server.ts (pendingPermissions + notifications/claude/channel/
# permission_request). If you auto-accept them here, the approval UX
# is silently bypassed. Leave that prompt alone so the plugin's
# permission-request notification can fire.
#
# TIOCSTI is disabled by default on Ubuntu 24.04+ (kernel security), so
# we use expect instead of the old Python PTY approach. expect is
# ubiquitous and reliable on every Linux distro.
#
# The bounded regex `.{1,30}` is important: Claude's TUI inserts
# `\033[1C` (cursor right) escape sequences between words in prompt
# text, so naive literal matching fails.
#
# Usage: autoaccept.exp <start-script>

set timeout 30
set start_sh [lindex $argv 0]
spawn /bin/bash -l $start_sh

expect {
    timeout {
        # Bounded autoaccept window — fall through to interact below so
        # external `tmux send-keys` (epic #725 Phase 2) can reach the
        # spawned shell. Without this the loop hangs forever and expect
        # owns stdin, dropping any injected keystrokes.
    }
    -re {Loading.{1,30}development.{1,30}channels} {
        # NEW dev-channels prompt wording (Claude Code mid-2026+):
        #   WARNING: Loading development channels
        #   ❯ 1. I am using this for local development
        #     2. Exit
        # Option 1 ("local development") is already highlighted, so just
        # press Enter — no Down keystroke needed. Tightly scoped to the
        # literal "Loading … development channels" warning header so we
        # don't over-match anywhere else.
        sleep 0.5
        send "\r"
        exp_continue
    }
    -re {using this for local development} {
        # Belt-and-suspenders for the new prompt: match on the option-row
        # text in case the WARNING header has scrolled out of the capture
        # window. Same scoping discipline — "local development" is unique
        # to this prompt and won't appear in per-tool confirmations.
        sleep 0.5
        send "\r"
        exp_continue
    }
    -re {I.{0,5}accept.{0,80}development.{0,10}channels} {
        # LEGACY dev-channels acknowledgement — old wording before the
        # 2026 TUI rename ("Yes, I accept the use of development channels").
        # Kept as a fallback for older Claude Code releases. Tightly scoped
        # to the literal "development channels" phrase to avoid over-matching
        # per-tool confirmations that start with "Yes, I accept" e.g.
        # "Yes, I accept this file edit." Those must fall through to the
        # plugin's permission_request flow.
        sleep 0.5
        send "\033\[B\r"
        exp_continue
    }
    -re {Use this and all future MCP servers} {
        # MCP server trust prompt
        sleep 0.5
        send "\r"
        exp_continue
    }
    -re {Choose.{1,30}text.{1,30}style} {
        # First-run theme selection — pick option 1 (Auto)
        sleep 0.5
        send "\r"
        exp_continue
    }
    -re {Anthropic.{1,80}Bedrock} {
        # First-run API provider selection — pick Anthropic (option 1)
        sleep 0.5
        send "\r"
        exp_continue
    }
    -re {Enter.{1,30}confirm} {
        # Generic "Enter to confirm" prompt (dev channels, trust dialog)
        sleep 0.8
        send "\r"
        exp_continue
    }
    eof
}

# After the autoaccept window closes, proxy stdin↔spawned process so
# external `tmux send-keys` reaches Claude's REPL (epic #725 Phase 2).
# Without `interact`, expect keeps stdin captured and any keystrokes
# tmux pipes into the pane are silently dropped.
interact {
    eof exit
}
