# switchroom/base — shared image for agent / broker / kernel / scheduler.
#
# Multi-arch: declare TARGETARCH so buildx (linux/amd64 + linux/arm64) picks
# the right artifacts. node:22-bookworm-slim has both arches upstream; tini
# and tmux are arch-portable from Debian repos.
#
# The claude CLI is installed via npm — the upstream package ships a thin
# JS launcher and downloads the correct platform binary on first run, so
# ARG TARGETARCH is informational here (logged at build time for forensics).
ARG TARGETARCH=amd64

FROM node:22-bookworm-slim

ARG TARGETARCH
RUN echo "switchroom/base building for arch=${TARGETARCH}" >&2

# tini: PID 1 in agent containers (zombie reap + signal forward).
# tmux: agent supervisor surface (#725).
# bash, ca-certificates, procps: shell + curl trust + ps for diagnostics.
# git: needed by claude tool calls + agent workflows.
# sqlite3: kernel.db / scheduler.db / hindsight bank inspection.
# openssh-client: claude bundle expects ssh-keygen for some flows.
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      tini \
      tmux \
      bash \
      ca-certificates \
      procps \
      git \
      sqlite3 \
      openssh-client \
      curl \
 && rm -rf /var/lib/apt/lists/*

# Pin claude CLI version in the base image so every agent / scheduler
# container resolves the SAME bundle. The version floats with the
# upstream tag at image-build time; agents do NOT install claude.
RUN npm install -g @anthropic-ai/claude-code@latest \
 && claude --version >&2 || true

# Default workdir; overridden by per-image Dockerfile if needed.
WORKDIR /opt/switchroom

# Identity defaults — overridden by compose `user:` directive at runtime.
# The base image itself is non-opinionated about UID; the compose generator
# allocates a per-agent UID and the agent service binds it.
