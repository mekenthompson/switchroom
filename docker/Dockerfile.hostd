# switchroom/hostd — host-control daemon container (RFC C Phase 1.5).
#
# Phase 1 (#1175) shipped the daemon as a library + protocol + opt-in
# flag, and recommended running it manually until packaging arrived.
# Phase 1.5 (this file) is that packaging: an image-pinned daemon
# managed by its own compose project (`switchroom-hostd`), separate
# from the main `switchroom` project so a `compose up -d --remove-
# orphans` cycle of the agent fleet cannot accidentally recreate the
# daemon mid-call.
#
# What hostd does at runtime:
#   1. Binds per-agent NDJSON UDS sockets at
#      /host-home/.switchroom/hostd/<agent>/sock (bind-mounted out to
#      ~/.switchroom/hostd/<agent>/sock on the host, which compose then
#      mounts into each admin agent's container at
#      /run/switchroom/hostd/<agent>/sock).
#   2. chowns each socket to the agent's UID, chmods 0o660, leaves the
#      enclosing dir 0o755 so the operator's compose-generator can
#      existsSync() it at apply time.
#   3. Listens for verb requests. Authorizes via SO_PEERCRED. Spawns
#      `switchroom <verb>` for the implementation. Audits every call
#      to ~/.switchroom/host-control-audit.log.
#
# Privileges:
#   - Runs as root inside the container (`USER 0:0`). Required for
#     CHOWN of agent sockets to non-root agent UIDs.
#   - Compose drops ALL caps and re-adds CHOWN, DAC_OVERRIDE, FOWNER.
#     no-new-privileges is set so the container can never bring back
#     privileges the operator didn't grant.
#   - docker.sock is bind-mounted — hostd shells out to
#     `switchroom <verb>` which itself shells out to `docker compose`
#     for restart / apply / update flows. This is the WHOLE POINT of
#     the daemon: admin agents go through hostd's audited verbs
#     instead of mounting docker.sock into every admin container.
#
# Multi-arch: switchroom/base sets up linux/amd64 + linux/arm64; both
# arches have node + tini + bash. The docker CLI install below uses
# Docker's official Debian-bookworm apt repo which ships both.

ARG BASE_IMAGE=switchroom/base:latest
FROM ${BASE_IMAGE}

ARG TARGETARCH=amd64
RUN echo "switchroom/hostd building for arch=${TARGETARCH}" >&2

# Install docker CLI + docker compose v2 plugin. Required because
# hostd's spawned switchroom CLI shells out to `docker compose` for
# every container-mutating verb. We deliberately do NOT install
# `docker-ce` (the daemon) — the daemon runs on the host and is
# accessed via the bind-mounted /var/run/docker.sock.
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      ca-certificates curl gnupg \
 && install -d -m 0755 /etc/apt/keyrings \
 && curl -fsSL https://download.docker.com/linux/debian/gpg \
    | gpg --dearmor -o /etc/apt/keyrings/docker.gpg \
 && chmod a+r /etc/apt/keyrings/docker.gpg \
 && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/debian bookworm stable" \
    > /etc/apt/sources.list.d/docker.list \
 && apt-get update \
 && apt-get install -y --no-install-recommends \
      docker-ce-cli \
      docker-compose-plugin \
 && rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*.deb

# Socket parent dir — keep 0o755 here so a stale Dockerfile-level
# default can't override what the daemon enforces at runtime.
# server.ts also chmods 0o755 explicitly on start() (see #1201).
RUN install -d -m 0755 /host-home /host-home/.switchroom

# Copy the bundled hostd entrypoint AND the switchroom CLI bundle.
# Hostd's `runSwitchroom(args)` (server.ts:499) spawns `switchroom`
# as a child process — the CLI must be on PATH or addressable via
# SWITCHROOM_CLI_PATH. We install at /usr/local/bin/switchroom for
# both (mirroring the agent image's wrapper script convention).
COPY dist/cli/switchroom.js /opt/switchroom/dist/cli/switchroom.js
COPY dist/host-control/main.js /opt/switchroom/dist/host-control/main.js

# Tiny wrapper so `switchroom <verb>` invocations from hostd resolve
# to the bundled CLI. Uses `bun` (not `node`) because the CLI bundle
# imports bun-specific modules (bun:sqlite, bun:test, etc. — produced
# by scripts/build.mjs's bundling pass that marks bun: imports as
# externals). Node throws ERR_UNSUPPORTED_ESM_URL_SCHEME on load.
# Mirrors the host's ~/.bun/bin/switchroom shim and the broker image's
# CMD which also runs under bun.
RUN printf '#!/bin/sh\nexec bun /opt/switchroom/dist/cli/switchroom.js "$@"\n' \
    > /usr/local/bin/switchroom \
 && chmod 0755 /usr/local/bin/switchroom

USER 0:0

# tini for clean signal forwarding to the node process. SIGTERM from
# `docker stop` reaches node within tini's grace period; node's
# signal handlers in main.ts run shutdown() and stop the server.
ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["node", "/opt/switchroom/dist/host-control/main.js"]
