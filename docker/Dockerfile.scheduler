# switchroom/scheduler — singleton cron container.
#
# Runs as root so it can mount /var/run/docker.sock and dispatch tasks
# via `docker exec agent-<name> claude -p <prompt>`. The scheduler does
# NOT see secret values — it only fires the dispatch; the agent resolves
# its own vault refs through the broker socket.
ARG BASE_IMAGE=switchroom/base:latest
FROM ${BASE_IMAGE}

ARG TARGETARCH=amd64
RUN echo "switchroom/scheduler building for arch=${TARGETARCH}" >&2

# Install the docker CLI so the scheduler can `docker exec` into agent
# containers via the bind-mounted /var/run/docker.sock. This is the
# CLI client only; the engine is the host's, mounted in.
RUN apt-get update \
 && apt-get install -y --no-install-recommends docker.io \
 && rm -rf /var/lib/apt/lists/*

# State dir for scheduler.db (audit trail of fires).
RUN mkdir -p /state/scheduler

# Config bind-mount target (the host's switchroom.yaml + cascade).
RUN mkdir -p /state/config

# Phase 1b: copy the bundled scheduler entrypoint. scripts/build.mjs
# emits dist/scheduler/index.js with native deps (better-sqlite3) and
# node-cron marked external — those are installed inside the image so
# the prebuilt better-sqlite3 binary matches the linux/glibc runtime,
# not whatever host ran `npm run build`.
COPY dist/scheduler/index.js /opt/switchroom/dist/scheduler/index.js

# Install runtime deps inside the image. better-sqlite3 prefers the
# prebuilt binary that ships in its npm tarball; if the platform isn't
# covered we'd need build-essential + python3 to compile from source —
# adding those falls back to /etc/Dockerfile.scheduler.from-source as
# the iteration target. node-cron is pure JS so always installs cleanly.
WORKDIR /opt/switchroom
RUN npm init -y >/dev/null \
 && node -e "const fs=require('fs');const p=JSON.parse(fs.readFileSync('package.json'));p.type='module';fs.writeFileSync('package.json',JSON.stringify(p,null,2));" \
 && npm install --omit=dev --build-from-source=false \
      better-sqlite3@^11.5.0 \
      node-cron@^3.0.3

USER 0:0

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["node", "/opt/switchroom/dist/scheduler/index.js"]
