{
  "permissions": {
    "allow": [{{#each permissionAllow}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}}],
    "deny": [{{#each tools.deny}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}}]{{#if defaultModeAcceptEdits}},
    "defaultMode": "acceptEdits"{{/if}}
  },
  "enabledPlugins": {
    "telegram@claude-plugins-official": true
  }{{#if hindsightEnabled}},
  "autoMemoryEnabled": false{{/if}}{{#if mcpServers}},
  "mcpServers": {{{json mcpServers}}}
  {{/if}}{{#if skipPermissionPrompt}},
  "skipDangerousModePermissionPrompt": true
  {{/if}}
}
